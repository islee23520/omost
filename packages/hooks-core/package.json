{
  "name": "@oh-my-opencode/hooks-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone OMO hook catalog extracted from the original plugin hook registry.",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./index.d.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external='@oh-my-opencode/*'",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts --coverage"
  },
  "dependencies": {
    "@oh-my-opencode/agents-md-core": "workspace:*",
    "@oh-my-opencode/comment-checker-core": "workspace:*",
    "@oh-my-opencode/model-core": "workspace:*",
    "@oh-my-opencode/rules-engine": "workspace:*",
    "@oh-my-opencode/ulw-kernel": "workspace:*",
    "@oh-my-opencode/utils": "workspace:*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "src",
    "index.d.ts"
  ]
}
