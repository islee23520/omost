{
  "name": "@oh-my-opencode/adapter-codex",
  "version": "0.1.0",
  "type": "module",
  "description": "Codex adapter that composes standalone OMO ULW domains into a Codex host port.",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./index.d.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external='@oh-my-opencode/*'",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts"
  },
  "dependencies": {
    "@oh-my-opencode/ulw-host-contract": "workspace:*",
    "@oh-my-opencode/ulw-kernel": "workspace:*",
    "@oh-my-opencode/ulw-loop-state": "workspace:*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "src",
    "index.d.ts"
  ]
}
