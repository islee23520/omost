{
  "name": "@oh-my-opencode/rules-engine",
  "version": "0.1.0",
  "type": "module",
  "description": "Pure TypeScript rule discovery, matching, and nested AGENTS.md context utilities for oh-my-opencode.",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./index.d.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm --external='@oh-my-opencode/*'",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts"
  },
  "dependencies": {
    "picomatch": "^4.0.4"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    "dist",
    "src",
    "index.d.ts"
  ]
}
